
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a single product available for sale in the inventory, managed via barcode or manual entry.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity. This is typically the EAN-13 barcode of the product."
        },
        "name": {
          "type": "string",
          "description": "The name or title of the product."
        },
        "price": {
          "type": "number",
          "description": "The current selling price of a single unit of the product."
        },
        "stock": {
          "type": "number",
          "description": "The available quantity of the product currently in stock."
        },
        "idealStock": {
          "type": "number",
          "description": "The desired amount of stock for this product to be considered in optimal state."
        },
        "warningStock": {
          "type": "number",
          "description": "A fixed threshold. If stock is below this number, the product is in danger state."
        },
        "category": {
          "type": "string",
          "description": "The category the product belongs to."
        },
        "distributor": {
          "type": "string",
          "description": "The name of the company or distributor providing the product."
        }
      },
      "required": [
        "id",
        "name",
        "price",
        "stock"
      ]
    },
    "Sale": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Sale",
      "type": "object",
      "description": "Represents a completed sales transaction.",
      "properties": {
        "id": {
          "type": "string"
        },
        "saleDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "totalAmount": {
          "type": "number"
        },
        "paymentMethod": {
          "type": "string",
          "enum": ["cash", "card"],
          "description": "The method used for the payment."
        },
        "productSaleItemIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "manualSaleItemIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [
        "id",
        "saleDateTime",
        "totalAmount"
      ]
    },
    "InventoryLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "InventoryLog",
      "type": "object",
      "description": "Represents an entry of new stock into the inventory.",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "invoiceNumber": { "type": "string", "description": "The invoice number associated with this stock entry." },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["restock", "adjustment"] }
      },
      "required": ["id", "productId", "productName", "quantity", "timestamp"]
    },
    "Note": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Note",
      "type": "object",
      "description": "A simple note or reminder.",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "content", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/authorizedUsers/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Authorized users of the POS system."
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "description": "Main inventory collection."
        }
      },
      {
        "path": "/sales/{saleId}",
        "definition": {
          "entityName": "Sale",
          "description": "Completed sales transactions."
        }
      },
      {
        "path": "/inventoryLogs/{logId}",
        "definition": {
          "entityName": "InventoryLog",
          "description": "Logs for stock additions and adjustments."
        }
      },
      {
        "path": "/notes/{noteId}",
        "definition": {
          "entityName": "Note",
          "description": "System reminders and notes."
        }
      }
    ]
  }
}

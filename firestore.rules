
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ALTODELBOSQUE POS SECURITY RULES
     * Version: 3.3 - Eliminada sección de BreadLogs
     */

    function isSignedIn() {
      return request.auth != null;
    }

    match /authorizedUsers/{userId} {
      allow get, create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow read, get, list: if isSignedIn();
      allow write, create, update, delete: if isSignedIn();
    }

    match /notes/{noteId} {
      allow read, write: if isSignedIn();
    }

    match /inventoryLogs/{logId} {
      allow read, write: if isSignedIn();
    }

    match /sales/{saleId} {
      allow read, write: if isSignedIn();

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ALTODELBOSQUE POS SECURITY RULES
     * Version: 1.5 - Despliegue forzado para sincronización global
     * Nota: La autorización depende del estado de sesión para evitar latencia de propagación de documentos.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorized() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /authorizedUsers/{userId} {
      allow get, create, update, delete: if isOwner(userId);
      allow list: if false;
    }

    match /products/{productId} {
      allow get, list, create, update, delete: if isAuthorized();
    }

    match /notes/{noteId} {
      allow get, list, create, update, delete: if isAuthorized();
    }

    match /inventoryLogs/{logId} {
      allow get, list, create, update, delete: if isAuthorized();
    }

    match /sales/{saleId} {
      allow get, list, create, update, delete: if isAuthorized();

      match /productSaleItems/{itemId} {
        allow get, list, create, update, delete: if isAuthorized();
      }

      match /manualSaleItems/{itemId} {
        allow get, list, create, update, delete: if isAuthorized();
      }
    }
  }
}

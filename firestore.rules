
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SMART SALE POS SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorized() {
      return isSignedIn() && exists(/databases/$(database)/documents/authorizedUsers/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    match /authorizedUsers/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    match /products/{productId} {
      allow get, list: if isAuthorized();
      allow create: if isAuthorized();
      allow update: if isAuthorized();
      allow delete: if isAuthorized();
    }

    match /notes/{noteId} {
      allow get, list: if isAuthorized();
      allow create: if isAuthorized();
      allow update: if isAuthorized();
      allow delete: if isAuthorized();
    }

    match /sales/{saleId} {
      allow get, list: if isAuthorized();
      allow create: if isAuthorized();
      allow update: if isAuthorized();
      allow delete: if isAuthorized();

      match /productSaleItems/{itemId} {
        allow get, list: if isAuthorized();
        allow create: if isAuthorized();
        allow update, delete: if isAuthorized();
      }

      match /manualSaleItems/{itemId} {
        allow get, list: if isAuthorized();
        allow create: if isAuthorized();
        allow update, delete: if isAuthorized();
      }
    }
  }
}
